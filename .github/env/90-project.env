# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for lucid
# Load Order: 90 (loaded after all defaults, overrides tool-specific settings)
#
# This file contains project-level configuration that overrides defaults from
# earlier env files (00-core, 10-*, 20-*). Use this for any settings that are
# specific to this repository.
#
# Maintainer: @mrz1836
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

GO_PRIMARY_VERSION=1.26.x
GO_SECONDARY_VERSION=1.26.x
MAGE_X_GO_SECONDARY_VERSION=1.26.x
MAGE_X_GO_VERSION=1.26.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Report Provider (overrides internal default to use codecov)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration (only used when provider=codecov)
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (matches codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,test/,testing/,vendor/,testdata/

# ================================================================================================
# 🔧 MAGE-X CONFIGURATION
# ================================================================================================

# Exclude specific tags from auto-discovery (comma-separated).
# Includes Go's reserved, environment-satisfied build constraints (all GOOS and
# GOARCH names plus toolchain/feature tokens) so auto-discovery never passes them
# as -tags. Without this, a //go:build darwin file (e.g. internal/schedstatus/host_darwin.go)
# makes mage-x run `go test -tags=darwin` on the linux CI runner, which also satisfies
# //go:build darwin in stdlib internal/goos alongside the linux files -> "GOOS redeclared"
# -> build fails -> no coverage.txt -> Codecov "Verify coverage file" fails.
# Custom tags (e.g. integration, e2e) are still discovered; go1.NN tags are skipped by mage-x.
MAGE_X_AUTO_DISCOVER_BUILD_TAGS_EXCLUDE=go1,go1.18,windows,stress,race,custom,msan,asan,cgo,gc,gccgo,boringcrypto,unix,aix,android,darwin,dragonfly,freebsd,hurd,illumos,ios,js,linux,nacl,netbsd,openbsd,plan9,solaris,wasip1,zos,386,amd64,amd64p32,arm,armbe,arm64,arm64be,loong64,mips,mipsle,mips64,mips64le,mips64p32,mips64p32le,ppc,ppc64,ppc64le,riscv,riscv64,s390,s390x,sparc,sparc64,wasm
